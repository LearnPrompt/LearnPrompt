---
const base = import.meta.env.BASE_URL === "/" ? "" : import.meta.env.BASE_URL.replace(/\/$/, "");
const withBase = (href: string) => (href.startsWith("/") ? `${base}${href}` : href);

const paths = [
  {
    title: "AI 编程入门",
    href: "/ai-coding/choose-claude-code-or-codex/",
    description: "从需求、计划、实现到验收，建立第一个可复用的 AI 编程闭环。",
    meta: "5 篇",
    tone: "violet",
    output: "产出任务卡",
  },
  {
    title: "Claude Code / Codex",
    href: "/claude-code/install-and-first-project/",
    description: "理解本地执行、云端任务、代码审查之间的边界和分工。",
    meta: "14 篇",
    tone: "blue",
    output: "产出可审查 diff",
  },
  {
    title: "Agent 工程",
    href: "/agent-engineering/what-is-harness/",
    description: "把模型能力放进可运行、可回滚、可观察、可验收的系统。",
    meta: "6 篇",
    tone: "mint",
    output: "产出反馈闭环",
  },
  {
    title: "Agent Skills",
    href: "/agent-skills/what-are-agent-skills/",
    description: "把稳定工作流包装成可复用的 Skill，而不是每次重新提示。",
    meta: "7 篇",
    tone: "amber",
    output: "产出 SKILL.md",
  },
  {
    title: "Obsidian AI",
    href: "/obsidian-ai/markdown-as-agent-memory/",
    description: "把 Markdown vault 变成 Agent 可读、可维护的长期工作台。",
    meta: "5 篇",
    tone: "rose",
    output: "产出长期上下文",
  },
];

const featured = [
  {
    title: "Claude Code 与 Codex 怎么选",
    href: "/ai-coding/choose-claude-code-or-codex/",
    note: "先确定任务归属，避免一开始就把工具用错。",
  },
  {
    title: "Agentic Coding 的最小工作流",
    href: "/ai-coding/minimum-agentic-coding-workflow/",
    note: "把 AI 编程压成计划、改动、验证、复盘四步。",
  },
  {
    title: "CLAUDE.md 最小可用模板",
    href: "/claude-code/minimum-claude-md/",
    note: "让项目规则真的影响模型行为，而不是只写口号。",
  },
  {
    title: "Codex 沙箱与权限模式怎么理解",
    href: "/codex/sandbox-and-permissions/",
    note: "知道什么时候可以放权，什么时候必须保守。",
  },
  {
    title: "第一个 SKILL.md 怎么写",
    href: "/agent-skills/first-skill-md/",
    note: "把常用流程包装成别人也能加载的稳定能力。",
  },
  {
    title: "Obsidian Vault 的 AI 友好目录设计",
    href: "/obsidian-ai/vault-directory-for-ai/",
    note: "让笔记库变成 Agent 能读、能维护的长期上下文。",
  },
];

const outputs = [
  ["任务卡", "把想法写成目标、边界、验收命令"],
  ["项目规则", "把反复踩坑的偏好写进 AGENTS 或 CLAUDE"],
  ["Skill 草稿", "把稳定流程拆成触发、输入、步骤、验收"],
  ["复盘记录", "把失败原因沉淀为下一次能复用的规则"],
];

const contactEmail = "carl@goodcase.ai";
const wechatId = "aiwarts101";
const mailSubject = encodeURIComponent("想和 LearnPrompt 聊聊");

---

<section class="lp-video-hero" data-od-id="video-hero">
  <video class="lp-video-bg" src="https://d8j0ntlcm91z4.cloudfront.net/user_38xzZboKViGWJOttwIXH07lWA1P/hf_20260508_155101_f2540600-6fe9-433e-8e48-b3f4b72f0727.mp4" autoplay loop muted playsinline></video>
  <div class="lp-video-content">
    <h1>把 AI 用进<br />真实项目</h1>
    <p>从会提问，走到会做项目、会搭 Agent、会沉淀自己的知识工作台。</p>
    <a class="lp-video-cta" href={withBase("/start-here/ai-practice-map/")}>开始学习</a>
  </div>
</section>

<div class="lp-home">
  <section class="lp-home-section lp-contrast" data-od-id="learning-promise">
    <div class="lp-promise-copy">
      <h2>每一页都要帮你多做出一步</h2>
      <p>
        不是把模型、插件和链接按热度堆起来，而是把一次 AI 实战拆成清楚的目标、边界、验收和复盘。
        你读完一页，就应该更接近一个能交付的结果。
      </p>
    </div>
    <div class="lp-promise-mark" aria-label="学习路径">
      <span>Prompt</span>
      <span>Project</span>
      <span>Skill</span>
    </div>
  </section>

  <section class="lp-home-section" data-od-id="learning-paths">
    <div class="lp-section-heading">
      <h2>
        <span>按目标进入，</span>
        <span>不用按目录顺序，</span>
        <span>就从不熟的开始。</span>
      </h2>
    </div>
    <div class="lp-path-grid">
      {paths.map((path, index) => (
        <a class:list={["lp-path-item", index === 0 && "is-featured"]} data-tone={path.tone} href={withBase(path.href)}>
          <span>{path.meta}</span>
          <h3>{path.title}</h3>
          <p>{path.description}</p>
          <em>{path.output}</em>
        </a>
      ))}
    </div>
  </section>

  <section class="lp-home-section lp-featured" data-od-id="featured-guides">
    <div class="lp-section-heading">
      <h2>第一次访问，先读这 6 篇</h2>
    </div>
    <div class="lp-featured-list">
      {featured.map((item, index) => (
        <a href={withBase(item.href)}>
          <span>{String(index + 1).padStart(2, "0")}</span>
          <strong>{item.title}<em>开始读</em></strong>
          <p>{item.note}</p>
        </a>
      ))}
    </div>
  </section>

  <section class="lp-home-section lp-use" data-od-id="how-to-use">
    <div>
      <h2>一条适合新人的实战顺序</h2>
    </div>
    <div class="lp-workbench-grid">
      {outputs.map(([title, description], index) => (
        <div class="lp-workbench-item">
          <span>{String(index + 1).padStart(2, "0")}</span>
          <strong>{title}</strong>
          <p>{description}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="lp-home-section lp-contact" data-od-id="contact">
    <div class="lp-contact-copy">
      <p class="lp-eyebrow">Contact</p>
      <h2>有想法找我聊聊吧</h2>
      <p>
        想一起做 AI 教程、Agent 工作流、Skill 包装，或者只是想反馈这个新版站点，都可以直接联系我。
      </p>
      <div class="lp-contact-actions">
        <a class="lp-button lp-button-primary" href={`mailto:${contactEmail}?subject=${mailSubject}`}>
          Send Email
        </a>
        <button class="lp-button lp-copy-button" type="button" data-copy-value={contactEmail} data-copy-success="已复制邮箱">
          复制邮箱
        </button>
        <button class="lp-button lp-copy-button" type="button" data-copy-value={wechatId} data-copy-success="已复制微信">
          复制微信
        </button>
      </div>
    </div>
    <div class="lp-contact-panel" aria-label="联系方式">
      <div class="lp-contact-row">
        <span>Email</span>
        <a href={`mailto:${contactEmail}?subject=${mailSubject}`}>{contactEmail}</a>
      </div>
      <div class="lp-contact-row">
        <span>WeChat</span>
        <button class="lp-contact-value lp-copy-button" type="button" data-copy-value={wechatId} data-copy-success="已复制微信">
          {wechatId}
        </button>
      </div>
    </div>
  </section>

  <section class="lp-home-section lp-legacy" data-od-id="legacy-site">
    <div class="lp-legacy-copy">
      <p class="lp-eyebrow">Legacy</p>
      <h2><span>旧版</span><span>LearnPrompt</span></h2>
      <p>
        如果你想回看旧版课程首页、旧导航和历史内容，可以从这里进入原来的 LearnPrompt。
      </p>
      <a class="lp-button lp-button-primary" href="https://v1.learnprompt.pro/" target="_blank" rel="noreferrer">
        访问旧版 LearnPrompt
      </a>
    </div>
    <a class="lp-legacy-preview" href="https://v1.learnprompt.pro/" target="_blank" rel="noreferrer" aria-label="访问旧版 LearnPrompt">
      <img src={withBase("/images/legacy-learnprompt-home.jpg")} alt="旧版 LearnPrompt 首页截图" loading="lazy" />
    </a>
  </section>
</div>

<script>
  document.querySelectorAll<HTMLButtonElement>(".lp-copy-button").forEach((button) => {
    const value = button.dataset.copyValue;
    const originalText = button.textContent || "复制";
    const successText = button.dataset.copySuccess || "已复制";
    if (!value) return;

    button.addEventListener("click", async () => {
      try {
        await navigator.clipboard.writeText(value);
        button.textContent = successText;
        window.setTimeout(() => {
          button.textContent = originalText;
        }, 1800);
      } catch {
        button.textContent = value;
      }
    });
  });
</script>
