{
  "type": "object",
  "additionalProperties": false,
  "required": [
    "status",
    "written_files",
    "all_cited_paths",
    "current_status",
    "accepted_decision",
    "rationale_and_evidence",
    "next_command",
    "known_limitation",
    "verification_date"
  ],
  "properties": {
    "status": {
      "type": "string",
      "const": "completed"
    },
    "written_files": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "items": {
        "type": "string"
      }
    },
    "all_cited_paths": {
      "type": "array",
      "minItems": 5,
      "maxItems": 5,
      "items": {
        "type": "string"
      }
    },
    "current_status": {
      "type": "string",
      "minLength": 12
    },
    "accepted_decision": {
      "type": "string",
      "minLength": 12
    },
    "rationale_and_evidence": {
      "type": "string",
      "minLength": 20
    },
    "next_command": {
      "type": "string",
      "minLength": 8
    },
    "known_limitation": {
      "type": "string",
      "minLength": 12
    },
    "verification_date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    }
  }
}
