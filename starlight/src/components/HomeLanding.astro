---
const base = import.meta.env.BASE_URL === "/" ? "" : import.meta.env.BASE_URL.replace(/\/$/, "");
const withBase = (href: string) => (href.startsWith("/") ? `${base}${href}` : href);

const paths = [
  {
    title: "AI 编程入门",
    href: "/ai-coding/choose-claude-code-or-codex/",
    description: "从需求、计划、实现到验收，建立第一个可复用的 AI 编程闭环。",
    meta: "5 篇",
    tone: "violet",
    output: "产出任务卡",
  },
  {
    title: "Claude Code / Codex",
    href: "/claude-code/install-and-first-project/",
    description: "理解本地执行、云端任务、代码审查之间的边界和分工。",
    meta: "14 篇",
    tone: "blue",
    output: "产出可审查 diff",
  },
  {
    title: "Agent 工程",
    href: "/agent-engineering/what-is-harness/",
    description: "把模型能力放进可运行、可回滚、可观察、可验收的系统。",
    meta: "6 篇",
    tone: "mint",
    output: "产出反馈闭环",
  },
  {
    title: "Agent Skills",
    href: "/agent-skills/what-are-agent-skills/",
    description: "把稳定工作流包装成可复用的 Skill，而不是每次重新提示。",
    meta: "7 篇",
    tone: "amber",
    output: "产出 SKILL.md",
  },
  {
    title: "Obsidian AI",
    href: "/obsidian-ai/markdown-as-agent-memory/",
    description: "把 Markdown vault 变成 Agent 可读、可维护的长期工作台。",
    meta: "5 篇",
    tone: "rose",
    output: "产出长期上下文",
  },
];

const featured = [
  {
    title: "Claude Code 与 Codex 怎么选",
    href: "/ai-coding/choose-claude-code-or-codex/",
    note: "先确定任务归属，避免一开始就把工具用错。",
  },
  {
    title: "Agentic Coding 的最小工作流",
    href: "/ai-coding/minimum-agentic-coding-workflow/",
    note: "把 AI 编程压成计划、改动、验证、复盘四步。",
  },
  {
    title: "CLAUDE.md 最小可用模板",
    href: "/claude-code/minimum-claude-md/",
    note: "让项目规则真的影响模型行为，而不是只写口号。",
  },
  {
    title: "Codex 沙箱与权限模式怎么理解",
    href: "/codex/sandbox-and-permissions/",
    note: "知道什么时候可以放权，什么时候必须保守。",
  },
  {
    title: "第一个 SKILL.md 怎么写",
    href: "/agent-skills/first-skill-md/",
    note: "把常用流程包装成别人也能加载的稳定能力。",
  },
  {
    title: "Obsidian Vault 的 AI 友好目录设计",
    href: "/obsidian-ai/vault-directory-for-ai/",
    note: "让笔记库变成 Agent 能读、能维护的长期上下文。",
  },
];

const outputs = [
  ["任务卡", "把想法写成目标、边界、验收命令"],
  ["项目规则", "把反复踩坑的偏好写进 AGENTS 或 CLAUDE"],
  ["Skill 草稿", "把稳定流程拆成触发、输入、步骤、验收"],
  ["复盘记录", "把失败原因沉淀为下一次能复用的规则"],
];

---

<div class="lp-home">
  <section class="lp-home-hero" data-od-id="home-hero">
    <div class="lp-home-copy">
      <svg class="lp-brand-ribbon" viewBox="0 0 320 52" role="presentation" aria-hidden="true" focusable="false">
        <defs>
          <linearGradient id="lp-ribbon-gradient" x1="0" x2="320" y1="0" y2="52" gradientUnits="userSpaceOnUse">
            <stop offset="0" stop-color="#240550" />
            <stop offset="0.48" stop-color="#6c4b96" />
            <stop offset="1" stop-color="#d5bded" />
          </linearGradient>
          <linearGradient id="lp-ribbon-glint" x1="0" x2="320" y1="0" y2="0" gradientUnits="userSpaceOnUse">
            <stop offset="0" stop-color="#ffffff" stop-opacity="0" />
            <stop offset="0.52" stop-color="#ffffff" stop-opacity="0.95" />
            <stop offset="1" stop-color="#ffffff" stop-opacity="0" />
          </linearGradient>
        </defs>
        <path class="lp-ribbon-track" d="M6 31 C 62 4 115 47 170 23 S 263 11 314 30" />
        <path class="lp-ribbon-shine" d="M6 31 C 62 4 115 47 170 23 S 263 11 314 30" />
      </svg>
      <p class="lp-eyebrow">LearnPrompt v2</p>
      <h1><span>把 AI 用进</span><span>真实项目</span></h1>
      <p class="lp-lede">
        从会提问，走到会做项目、会搭 Agent、会沉淀自己的知识工作台。
        新版 LearnPrompt 是一套面向普通 AI 爱好者的中文实战课程，而不是工具链接集合。
      </p>
      <div class="lp-home-actions">
        <a class="lp-button lp-button-primary" href={withBase("/start-here/ai-practice-map/")}>
          开始学习
        </a>
        <a class="lp-button" href={withBase("/ai-coding/choose-claude-code-or-codex/")}>
          进入 AI 编程路径
        </a>
      </div>
      <div class="lp-home-proof" aria-label="站点状态">
        <span><strong>40+</strong> 首批教程</span>
        <span><strong>5</strong> 条学习路径</span>
        <span><strong>0</strong> 广告脚本</span>
      </div>
    </div>

    <div class="lp-home-studio" aria-label="LearnPrompt 学习工作台预览">
      <div class="lp-studio-top">
        <strong>从一个想法到可发布项目</strong>
        <span>需求会被拆成能执行、能验收、能复用的路径。</span>
      </div>
      <div class="lp-studio-body">
        <div class="lp-studio-query">
          <strong>“我想用 AI 做一个可发布项目”</strong>
          <p>先别急着选工具，先让问题变清楚。</p>
        </div>
        <div class="lp-studio-route">
          <h2>想法变成任务卡</h2>
          <svg class="lp-route-flow" viewBox="0 0 320 92" role="presentation" aria-hidden="true" focusable="false">
            <path class="lp-route-flow-line" d="M23 54 C 78 16 128 78 177 43 S 257 20 297 52" />
            <g class="lp-route-node-group">
              <circle cx="23" cy="54" r="7" />
              <circle cx="108" cy="48" r="7" />
              <circle cx="206" cy="39" r="7" />
              <circle cx="297" cy="52" r="7" />
            </g>
          </svg>
          <p>再交给 Codex / Claude Code 执行、审查、发布，最后沉淀为自己的 Skill。</p>
        </div>
        <div class="lp-studio-steps">
          <span><strong>01</strong> 写清需求</span>
          <span><strong>02</strong> 选择工具</span>
          <span><strong>03</strong> 验收发布</span>
        </div>
      </div>
    </div>
  </section>

  <section class="lp-home-section lp-contrast" data-od-id="learning-promise">
    <div class="lp-promise-copy">
      <h2>每一页都要帮你多做出一步</h2>
      <p>
        不是把模型、插件和链接按热度堆起来，而是把一次 AI 实战拆成清楚的目标、边界、验收和复盘。
        你读完一页，就应该更接近一个能交付的结果。
      </p>
    </div>
    <div class="lp-promise-mark" aria-label="学习路径">
      <span>Prompt</span>
      <span>Project</span>
      <span>Skill</span>
    </div>
  </section>

  <section class="lp-home-section" data-od-id="learning-paths">
    <div class="lp-section-heading">
      <h2>按目标进入，不用从目录硬读</h2>
    </div>
    <div class="lp-path-grid">
      {paths.map((path, index) => (
        <a class:list={["lp-path-item", index === 0 && "is-featured"]} data-tone={path.tone} href={withBase(path.href)}>
          <span>{path.meta}</span>
          <h3>{path.title}</h3>
          <p>{path.description}</p>
          <em>{path.output}</em>
        </a>
      ))}
    </div>
  </section>

  <section class="lp-home-section lp-featured" data-od-id="featured-guides">
    <div class="lp-section-heading">
      <h2>第一次访问，先读这 6 篇</h2>
    </div>
    <div class="lp-featured-list">
      {featured.map((item, index) => (
        <a href={withBase(item.href)}>
          <span>{String(index + 1).padStart(2, "0")}</span>
          <strong>{item.title}<em>开始读</em></strong>
          <p>{item.note}</p>
        </a>
      ))}
    </div>
  </section>

  <section class="lp-home-section lp-use" data-od-id="how-to-use">
    <div>
      <h2>一条适合新人的实战顺序</h2>
    </div>
    <div class="lp-workbench-grid">
      {outputs.map(([title, description], index) => (
        <div class="lp-workbench-item">
          <span>{String(index + 1).padStart(2, "0")}</span>
          <strong>{title}</strong>
          <p>{description}</p>
        </div>
      ))}
    </div>
  </section>
</div>
