const archivedProjects: Project[] = [];

async function fetchStars(project: Project): Promise<number> {
  try {
    const controller = new AbortController();
    const timer = setTimeout(() => controller.abort(), 5000);
    const headers: Record<string, string> = {
      Accept: "application/vnd.github+json",
    };
    if (import.meta.env.GITHUB_TOKEN) {
      headers.Authorization = `Bearer ${import.meta.env.GITHUB_TOKEN}`;
    }
    const res = await fetch(`https://api.github.com/repos/${project.repo}`, {
      headers,
      signal: controller.signal,
    });
    clearTimeout(timer);
    if (!res.ok) return project.fallbackStars;
    const data = await res.json();
    if (typeof data.stargazers_count !== "number") return project.fallbackStars;
    return data.stargazers_count;
  } catch {
    return project.fallbackStars;
  }
}

const withStars = async (projects: Project[]) =>
  Promise.all(projects.map(async (p) => ({ ...p, stars: await fetchStars(p) })));

const active = await withStars(activeProjects);
const stable = await withStars(stableProjects);
const archived = await withStars(archivedProjects);

const formatStars = (n: number) => (n >= 1000 ? `${(n / 1000).toFixed(1)}k` : String(n));
